[init]
	defaultBranch = main

[user]
	name = ss0923
	email = steele@steelesh.dev
	signingkey = D5E3B93FD52C1E96

[push]
	autoSetupRemote = true

[pull]
	rebase = true

[fetch]
	prune = true
	pruneTags = true
	fsckObjects = true

[rebase]
	autoStash = true
	autoSquash = true
	updateRefs = true
	missingCommitsCheck = error

[commit]
	verbose = true
	gpgsign = true

[gpg]
	program = gpg

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = ansi
	dark = true
	line-numbers-left-style = "#505050"
	line-numbers-right-style = "#505050"
	line-numbers-minus-style = "#ff8080"
	line-numbers-plus-style = "#99ffe4"
	hyperlinks = true
	hyperlinks-file-link-format = "file://{path}:{line}"

[merge]
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	colorMoved = default

[rerere]
	enabled = true

[branch]
	sort = -committerdate

[column]
	ui = auto

[transfer]
	fsckObjects = true

[receive]
	fsckObjects = true

[alias]
	dft = -c diff.external=difft diff
	dlog = -c diff.external=difft log --ext-diff
	dshow = -c diff.external=difft show --ext-diff
	undo = reset HEAD~1 --mixed
	recent = branch --sort=-committerdate --format='%(committerdate:relative)%09%(refname:short)' --count=10
	root = rev-parse --show-toplevel
	wip = "!git add -A && git commit -m 'chore: wip [skip ci]'"
	absorb = !git-absorb --and-rebase

[help]
	autocorrect = prompt

[tag]
	sort = version:refname

[maintenance]
	auto = true
	strategy = incremental

[absorb]
	maxStack = 50

[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential

[includeIf "gitdir:~/dev/personal/"]
	path = ~/.config/git/config-personal

[includeIf "gitdir:~/dev/manifest/"]
	path = ~/.config/git/config-manifest
